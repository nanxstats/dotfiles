{
    "editor.fontSize": 20,
    "editor.fontFamily": "'Anthrosevka Mono', 'Berkeley Mono Variable', 'Cascadia Code', 'Fira Code', 'Geist Mono', Hasklig, Inconsolata, 'Iosevka Extended', 'JetBrains Mono', 'Liga DM Mono', 'Liga Noto Sans Mono', 'Liga Paper Mono', 'Liga Share Tech Mono', 'Liga TheSansMonoOffice', 'Lilex', 'Maple Mono', 'Monaspace Argon', 'MonoLisaCode', 'SF Mono', 'Source Code Pro', 'TheSansMono Office', 'Twilio Sans Mono Retina', Menlo, Monaco, 'Courier New', monospace",
    "editor.fontLigatures": "'calt', 'liga'", // All others supporting coding ligatures
    // "editor.fontVariations": "'wght' 450", // Berkeley Mono Variable
    // "editor.fontLigatures": "'calt', 'liga', 'ss03', 'ss06', 'cv01', 'cv02', 'cv03', 'cv04', 'cv05', 'cv08', 'cv09'", // MonoLisaCode
    // "editor.fontLigatures": "'calt', 'liga', 'lnum', 'zero', 'cv01'", // TheSansMono
    // "editor.fontLigatures": "'calt', 'liga', 'zero', 'cv02', 'cv10', 'ss03', 'ss05'", // Fira Code
    // "editor.fontLigatures": "'calt', 'liga', 'ss03', 'ss04'", // Geist Mono
    // "editor.fontLigatures": "'calt', 'liga', 'zero','cv02', 'cv15'", // Lilex
    // "editor.fontLigatures": "'calt', 'liga', 'cv01', 'cv02'", // Maple Mono
    // "editor.fontLigatures": "'calt', 'liga', 'ss01', 'ss02', 'ss03', 'ss05', 'ss07'", // Monaspace Argon
    "editor.rulers": [
        80
    ],
    "editor.wordWrap": "on",
    "editor.inlineSuggest.enabled": true,
    "editor.copyWithSyntaxHighlighting": false,
    "editor.unicodeHighlight.nonBasicASCII": true,
    "editor.renderWhitespace": "trailing",
    "diffEditor.ignoreTrimWhitespace": false,
    "terminal.integrated.fontFamily": "'Liga Share Tech Mono', monospace",
    "terminal.integrated.fontLigatures.enabled": true,
    "terminal.integrated.fontSize": 18,
    "workbench.startupEditor": "none",
    "workbench.editor.empty.hint": "hidden",
    "window.autoDetectColorScheme": true,
    "workbench.preferredLightColorTheme": "textmate.rstheme",
    "workbench.preferredDarkColorTheme": "Ayu Mirage Bordered",
    "update.mode": "none",
    "telemetry.telemetryLevel": "off",
    "git.addAICoAuthor": "off"
}